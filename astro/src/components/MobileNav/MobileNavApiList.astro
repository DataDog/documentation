---
/**
 * The API documentation menu for the mobile nav, shown on `/api/` pages in
 * place of the main docs accordion.
 *
 * Each category is a collapsible <details> section with a rotating chevron.
 * The active category starts expanded; all others start collapsed. This lets
 * users browse and navigate to operations in any category without leaving
 * the current page.
 */
import type { ApiCategory } from "@lib/api/schemas/views";
import styles from "./MobileNav.module.css";
import { classListFactory } from "@lib/cssUtils/classListFactory";
import { localizedHref, type Locale } from "@lib/i18n/locale";

interface Props {
  categories: ApiCategory[];
  activeCategorySlug?: string;
  currentOperationSlug?: string;
  lang: Locale;
}

const { categories, activeCategorySlug, currentOperationSlug, lang } = Astro.props;
const cl = classListFactory(styles);
---

<ul class={cl("mobile-nav__list")}>
  {
    categories.map((category) => {
      const isActiveCategory = category.slug === activeCategorySlug;
      const categoryHref = localizedHref(lang, `/api/latest/${category.slug}/`);
      const isCategoryLandingPage = isActiveCategory && !currentOperationSlug;
      return (
        <li>
          <details
            class={cl("mobile-nav__api-section")}
            open={isActiveCategory || undefined}
          >
            <summary
              class:list={[
                cl("mobile-nav__api-section-toggle"),
                isCategoryLandingPage && cl("mobile-nav__api-category--active"),
              ]}
              aria-current={isCategoryLandingPage ? "page" : undefined}
            >
              <span>{category.name}</span>
              <span class={cl("mobile-nav__caret")} aria-hidden="true">
                <svg viewBox="0 0 17.78 10.51" width="18">
                  <polyline
                    class={cl("mobile-nav__caret-arrow")}
                    points="16.92 1.14 8.92 9.14 0.92 1.14"
                  />
                </svg>
              </span>
            </summary>
            <ul class={cl("mobile-nav__api-operations")}>
              {category.operations.map((operation) => {
                const isActiveOperation =
                  isActiveCategory && operation.slug === currentOperationSlug;
                return (
                  <li>
                    <a
                      href={`${categoryHref}${operation.slug}/`}
                      class:list={[
                        cl("mobile-nav__api-operation"),
                        isActiveOperation &&
                          cl("mobile-nav__api-operation--active"),
                      ]}
                      aria-current={isActiveOperation ? "page" : undefined}
                    >
                      {operation.summary}
                    </a>
                  </li>
                );
              })}
            </ul>
          </details>
        </li>
      );
    })
  }
</ul>

{/* Scroll the current page near the top of the panel, just below the sticky
    header, so it's visible the moment the overlay opens. Runs inline at parse
    time; the panel is laid out (fixed position, fixed height) even while it
    sits off-screen, so its scrollTop can be set before first paint. */}
<script is:inline>
  {
    const panel = document.getElementById("mobile-nav");
    const active =
      panel?.querySelector(".mobile-nav__api-operation--active") ??
      panel?.querySelector(".mobile-nav__api-category--active");
    const header = panel?.querySelector(".mobile-nav__header");
    if (panel && active) {
      const headerHeight = header
        ? header.getBoundingClientRect().height
        : 0;
      const gap = 12;
      panel.scrollTop +=
        active.getBoundingClientRect().top -
        panel.getBoundingClientRect().top -
        headerHeight -
        gap;
    }
  }
</script>
