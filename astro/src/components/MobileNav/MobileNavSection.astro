---
/**
 * Renders one node of the documentation nav tree as part of the mobile
 * accordion. A node with children becomes a native `<details>` (zero-JS,
 * accessible, multiple-open) whose `<summary>` is the toggle; a leaf becomes a
 * plain link. Recurses into itself for arbitrary depth, mirroring Hugo's
 * `mobile-documentation.html`.
 */
import type { DocsNavNode } from "@lib/componentUtils/docsNavMenu";
import styles from "./MobileNav.module.css";
import { classListFactory } from "@lib/cssUtils/classListFactory";
import Self from "./MobileNavSection.astro";
import { HUGO_ORIGIN } from "@config/origins";

interface Props {
  node: DocsNavNode;
  level: number;
  open?: boolean;
  /** Identifier of the node that is the current page, brand-colored when matched. */
  activePageId?: string;
}

const { node, level, open = false, activePageId } = Astro.props;
const cl = classListFactory(styles);
const hasChildren = node.children.length > 0;
const isActivePage = activePageId !== undefined && node.identifier === activePageId;

// Second-stage href resolution: `docsNavMenu.getDocsNavTree` already localizes
// and root-relativizes each URL; here we choose the origin. API docs (/api/...)
// are served by this Astro site, so they stay relative; all other links point
// at the Hugo site.
function resolveNavHref(href: string | null): string {
  if (!href) return HUGO_ORIGIN + "/";
  if (href.startsWith("/api/")) return href;
  if (href.startsWith("http://") || href.startsWith("https://")) return href;
  if (href.startsWith("#")) return href;
  return HUGO_ORIGIN + href;
}
---

{
  hasChildren ? (
    <details
      class={cl("mobile-nav__section")}
      data-level={level}
      style={`--depth:${level}`}
      open={open}
    >
      <summary class={cl("mobile-nav__section-toggle")}>
        <span>{node.label}</span>
        <span class={cl("mobile-nav__caret")} aria-hidden="true">
          <svg viewBox="0 0 17.78 10.51" width="18">
            <polyline
              class={cl("mobile-nav__caret-arrow")}
              points="16.92 1.14 8.92 9.14 0.92 1.14"
            />
          </svg>
        </span>
      </summary>
      <ul class={cl("mobile-nav__sublist")}>
        {/* A section that is itself a page stays reachable via its own link,
            matching Hugo's "add parent url as a child nav item". */}
        {node.href && (
          <li>
            <a
              class:list={[
                cl("mobile-nav__link"),
                isActivePage && cl("mobile-nav__link--active"),
              ]}
              style={`--depth:${level + 1}`}
              href={resolveNavHref(node.href)}
              aria-current={isActivePage ? "page" : undefined}
            >
              {node.label}
            </a>
          </li>
        )}
        {node.children.map((child) => (
          <li>
            <Self node={child} level={level + 1} activePageId={activePageId} />
          </li>
        ))}
      </ul>
    </details>
  ) : (
    <a
      class:list={[
        cl("mobile-nav__link"),
        isActivePage && cl("mobile-nav__link--active"),
      ]}
      data-level={level}
      style={`--depth:${level}`}
      href={resolveNavHref(node.href)}
      aria-current={isActivePage ? "page" : undefined}
    >
      {node.label}
    </a>
  )
}
