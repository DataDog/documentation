---
/**
 * Mobile navigation overlay, ported from Hugo's `mobile-documentation.html`:
 * a quick-links row (Home / Docs / API with icons), a search box, and the full
 * documentation menu rendered as a `<details>` accordion, all sections collapsed
 * by default.
 *
 * The menu tree is large, so it is rendered here at build time and never
 * serialized into a Preact island. Only the small `MobileNavToggle` island
 * (hamburger + open/close) is hydrated; it lives in the header's mobile row
 * (see Header.astro) and manipulates this already-rendered overlay via element
 * references, so this component renders only the backdrop and panel.
 */
import styles from "./MobileNav.module.css";
import { classListFactory } from "@lib/cssUtils/classListFactory";
import MobileNavSection from "./MobileNavSection.astro";
import SearchBar, {
  type SearchBarLabels,
} from "@components/SearchBar/SearchBar";
import { getDocsNavTree } from "@lib/componentUtils/docsNavMenu";
import { CORP_ORIGIN } from "@config/origins";
import { DEFAULT_LOCALE, localizedHref, type Locale } from "@lib/i18n/locale";
import { i18n } from "@lib/i18n/i18n";

interface Props {
  lang?: Locale;
}

const { lang = DEFAULT_LOCALE } = Astro.props;
const cl = classListFactory(styles);

const tree = getDocsNavTree(lang);

// TODO: replace hardcoded English fallbacks with i18n() keys once authoritative
// translations exist in the Hugo i18n bundle.
const quicknav = [
  { label: i18n("home"), href: CORP_ORIGIN, icon: "nav_home", alt: "home" },
  { label: i18n("docs") || "Docs", href: localizedHref(lang, "/"), icon: "nav_docs", alt: "docs" },
  { label: i18n("api"), href: localizedHref(lang, "/api/"), icon: "nav_mobile_api", alt: "api" },
];
// TODO: replace hardcoded English with i18n() once authoritative translation
// keys exist for these strings in the Hugo i18n bundle.
const searchLabels: SearchBarLabels = {
  Search: "Search",
  "Search documentation": "Search documentation",
  "Search documentation...": "Search documentation...",
  "No results.": "No results.",
};
---

<div id="mobile-nav-root">
  <div id="mobile-nav-bg" class={cl("mobile-nav__backdrop")}></div>

  <div id="mobile-nav" class={cl("mobile-nav__panel")}>
    <div class={cl("mobile-nav__quicknav")}>
      {
        quicknav.map((item) => (
          <a class={cl("mobile-nav__quicknav-link")} href={item.href}>
            <img
              class={cl("mobile-nav__quicknav-icon")}
              src={`/images/icons/${item.icon}.png`}
              width="21"
              height="21"
              loading="lazy"
              alt={item.alt}
            />
            <span>{item.label}</span>
          </a>
        ))
      }
    </div>

    <div class={cl("mobile-nav__search")}>
      <SearchBar client:load variant="mobile" labels={searchLabels} />
    </div>

    <ul class={cl("mobile-nav__list")}>
      {
        tree.map((node) => (
          <li>
            <MobileNavSection node={node} level={0} />
          </li>
        ))
      }
    </ul>
  </div>
</div>
