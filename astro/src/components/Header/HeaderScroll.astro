---
// Inline scroll listener that toggles the `.main-nav-scrolled` class on
// <html> once the user has scrolled past the threshold. The class drives
// the discrete shrink: nav 130→65px, bits logo 75→50px, wordmark hidden,
// and the LogoDownloadPanel offset. Matches Hugo's Tailwind nav partial
// (`tailwind-main-nav.html` toggles `navScrolled` at `scrollY > 30`).
---

<script is:inline>
  (function () {
    var root = document.documentElement;
    var DESKTOP_MIN_WIDTH = parseInt(
      getComputedStyle(document.documentElement)
        .getPropertyValue('--hugo-breakpoint-desktop')
    );
    var SCROLLED_THRESHOLD = 30;
    var ticking = false;

    function update() {
      var scrolled = window.innerWidth >= DESKTOP_MIN_WIDTH
        && window.scrollY > SCROLLED_THRESHOLD;
      if (scrolled) {
        root.classList.add('main-nav-scrolled');
      } else {
        root.classList.remove('main-nav-scrolled');
      }
      ticking = false;
    }

    function onScroll() {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(update);
    }

    update();
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });
  })();
</script>
