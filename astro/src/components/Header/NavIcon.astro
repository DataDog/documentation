---
/**
 * Renders a websites-modules iconfont icon via <i class="icon-{name}">.
 * Matches Hugo's approach of using the shared iconfont rather than inlining SVGs.
 */
interface Props {
  name: string;
  class?: string;
  size?: string;
}

const { name, class: className, size } = Astro.props;
const style = size ? `font-size:${size}` : undefined;
---

<i class={`icon-${name} nav-icon ${className ?? ''}`} style={style} aria-hidden="true" />

<style is:global>
  .nav-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
  }
</style>
