---
import styles from './Header.module.css';
import './ProductMegaMenu.css';
import NavDropdown from './NavDropdown.tsx';
import ProductMegaMenu, {
  type MegaCategory,
  type MegaSubcategory,
  type MegaSection,
} from './ProductMegaMenu.tsx';
import NavIcon from './NavIcon.astro';
import LogoDownloadPanel from './LogoDownloadPanel.astro';
import HeaderScroll from './HeaderScroll.astro';
import MobileNav from '../MobileNav/MobileNav.tsx';
import {
  getMainLeft,
  getMainRight,
  getDesktopCategories,
  getMobileCategories,
  getProduct,
  isDisabledForDocs,
  resolveUrl,
  type MenuItem,
} from '../../lib/menuData';
import { i18n } from '../../lib/i18n/i18n';

const mainLeft = getMainLeft();
const mainRight = getMainRight();
const categories = getDesktopCategories();
const mobileCategoriesRaw = getMobileCategories();

// Raw SVG import for the carrot icon used in the mega-menu's pricing link.
const carrotSvgModule = await import('../../mocked_dependencies/websites_modules/static/icons/right-carrot-normal-2.svg?raw');
const carrotSvg = carrotSvgModule.default as string;

// Raw imports for each product-category icon, keyed by the category's `icon` field.
const categoryIconMap: Record<string, string> = import.meta.glob<string>(
  '../../mocked_dependencies/websites_modules/static/icons/*.svg',
  { query: '?raw', import: 'default', eager: true }
);

function iconHtmlFor(name: string): string {
  const key = `../../mocked_dependencies/websites_modules/static/icons/${name}.svg`;
  return categoryIconMap[key] ?? '';
}

// Assemble the mega-menu data structure (translated, URL-resolved).
const megaCategories: MegaCategory[] = categories.map((cat) => {
  const subcategories: MegaSubcategory[] = (cat.children ?? []).map((sub) => {
    const sections: MegaSection[] = sub.sections
      ? sub.sections.map((section) => ({
          label: i18n(section.lang_key),
          products: section.products
            .map((id) => {
              const p = getProduct(id);
              return p ? { identifier: p.identifier, label: i18n(p.lang_key), url: resolveUrl(p.url) } : null;
            })
            .filter((p): p is { identifier: string; label: string; url: string } => p !== null),
        }))
      : sub.products
      ? [{
          label: i18n(sub.lang_key),
          products: sub.products
            .map((id) => {
              const p = getProduct(id);
              return p ? { identifier: p.identifier, label: i18n(p.lang_key), url: resolveUrl(p.url) } : null;
            })
            .filter((p): p is { identifier: string; label: string; url: string } => p !== null),
        }]
      : [];

    return {
      identifier: sub.identifier,
      label: i18n(sub.lang_key),
      related: sub.identifier.includes('related'),
      sections,
    };
  });

  return {
    identifier: cat.identifier,
    label: i18n(cat.lang_key),
    descriptionLabel: i18n(cat.description_key),
    gradient: cat.gradient ?? ['#000000', '#333333'],
    iconHtml: iconHtmlFor(cat.icon),
    subcategories,
  };
});

const productItem = mainLeft.find((m) => m.identifier === 'product');
const solutionsItem = mainLeft.find((m) => m.identifier === 'solutions');
const simpleLeftItems = mainLeft.filter(
  (m) => m.identifier !== 'product' && m.identifier !== 'solutions' && m.identifier !== 'search' && !isDisabledForDocs(m),
);

const aboutItem = mainRight.find((m) => m.identifier === 'about');
const blogItem = mainRight.find((m) => m.identifier === 'blog');
const loginItem = mainRight.find((m) => m.identifier === 'login');
const getStartedItem = mainRight.find((m) => m.identifier === 'get_started');

// Solutions columns — flatten the tree for easy rendering.
type SolutionsColumn = { label: string; items: { label: string; url: string }[] };
const solutionsColumns: SolutionsColumn[] = (solutionsItem?.children ?? []).map((col) => ({
  label: i18n(col.lang_key),
  items: (col.children ?? []).map((child) => ({
    label: i18n(child.lang_key),
    url: resolveUrl(child.url),
  })),
}));

function simpleChildren(item: MenuItem | undefined) {
  if (!item) return [];
  return (item.children ?? []).map((child) => ({
    label: i18n(child.lang_key),
    url: resolveUrl(child.url),
  }));
}

const aboutChildren = simpleChildren(aboutItem);
const blogChildren = simpleChildren(blogItem);

// Mobile nav data — pre-shaped so MobileNav.tsx doesn't need to import
// menuData/i18n/yaml on the client (was adding ~130KB to the island bundle).
const mobileItems = mainLeft
  .filter((m) => !isDisabledForDocs(m))
  .map((item) => ({
    identifier: item.identifier,
    label: i18n(item.lang_key),
    url: resolveUrl(item.url),
  }));

const mobileCategoriesData = mobileCategoriesRaw.map((cat) => ({
  identifier: cat.identifier,
  label: i18n(cat.lang_key),
  products: (cat.mobile_products ?? [])
    .map((id) => {
      const p = getProduct(id);
      return p ? { identifier: p.identifier, label: i18n(p.lang_key), url: resolveUrl(p.url) } : null;
    })
    .filter((p): p is { identifier: string; label: string; url: string } => p !== null),
}));

const mobileNavQuicknav = {
  home: i18n('home'),
  docs: i18n('docs') || 'Docs',
  api: i18n('api'),
};
const mobileNavSearch = { placeholder: 'Search', ariaLabel: 'Search' };

const bitsLogoUrl = 'https://imgix.datadoghq.com/img/dd_logo_n_70x75.png?ch=Width,DPR&fit=max&auto=format&w=70&h=75';
const textLogoUrl = 'https://imgix.datadoghq.com/img/dd-logo-n-200.png?ch=Width,DPR&fit=max&auto=format&h=14&auto=format&w=807';
const mobileLogoUrl = 'https://imgix.datadoghq.com/img/datadog_rbg_n_2x.png';
const mobileLogoSrcset = `${mobileLogoUrl} 1x, ${mobileLogoUrl}?dpr=2 2x`;
---

<div class="main-nav-wrapper">
  <nav class={`${styles.nav} main-nav`}>
    <div class={styles.container}>
      {/* Desktop layout */}
      <div class={styles.desktop}>
        <ul class={`${styles.leftList} main-left`}>
          {productItem && (
            <ProductMegaMenu
              client:load
              label={i18n(productItem.lang_key)}
              href={resolveUrl(productItem.url)}
              categories={megaCategories}
              pricingLabel={i18n('view_pricing')}
              pricingHref={resolveUrl('pricing/')}
              hype={i18n('product_hype')}
              carrotSvg={carrotSvg}
              classes={{
                menuItem: styles.menuItem,
                menuItemOpen: styles['menuItem--open'],
                menuLink: styles.menuLink,
                dropdownMenu: styles.dropdownMenu,
                dropdownMenuOpen: styles['dropdownMenu--open'],
              }}
            />
          )}

          {simpleLeftItems.map((item) => (
            <li class={`${styles.menuItem} ${item.identifier}-item`}>
              <a class={`${styles.menuLink} ${item.identifier}-menu`} href={resolveUrl(item.url)}>
                <span class="menu-text">{i18n(item.lang_key)}</span>
              </a>
            </li>
          ))}

          {solutionsItem && (
            <NavDropdown
              client:load
              label={i18n(solutionsItem.lang_key)}
              href={resolveUrl(solutionsItem.url)}
              identifier="solutions"
              isSolutions={true}
              classes={{
                menuItem: styles.menuItem,
                menuItemOpen: styles['menuItem--open'],
                menuLink: styles.menuLink,
                dropdownMenu: styles.dropdownMenu,
                dropdownMenuOpen: styles['dropdownMenu--open'],
                solutionsMenu: styles.solutionsMenu,
              }}
            >
              <div class={styles.solutionsGrid}>
                {solutionsColumns.map((col) => (
                  <div class={styles.solutionsColumn}>
                    <p class={styles.solutionsHeader}>{col.label}</p>
                    <ul class={styles.solutionsList}>
                      {col.items.map((item) => (
                        <li>
                          <a href={item.url}>
                            <span class={styles.menuText}>{item.label}</span>
                          </a>
                        </li>
                      ))}
                    </ul>
                  </div>
                ))}
              </div>
            </NavDropdown>
          )}
        </ul>

        {/* Logo */}
        <div class="header__logoSlot">
          <a href="/" class={`${styles.logoColumn} js-logo-download`}>
            <img
              height="75"
              class={styles.logoBits}
              src={bitsLogoUrl}
              srcset={`${bitsLogoUrl} 1x, ${bitsLogoUrl}&dpr=2 2x`}
              alt="Datadog"
            />
            <img
              class={styles.logoText}
              height="14"
              src={textLogoUrl}
              srcset={`${textLogoUrl} 1x, ${textLogoUrl}&dpr=2 2x`}
              alt="Datadog"
            />
            <LogoDownloadPanel />
          </a>
        </div>

        <ul class={`${styles.rightList} main-right`}>
          {aboutItem && (
            <NavDropdown
              client:load
              label={i18n(aboutItem.lang_key)}
              href={resolveUrl(aboutItem.url)}
              identifier="about"
              classes={{
                menuItem: styles.menuItem,
                menuItemOpen: styles['menuItem--open'],
                menuLink: styles.menuLink,
                dropdownMenu: styles.dropdownMenu,
                dropdownMenuOpen: styles['dropdownMenu--open'],
              }}
            >
              <ul style="list-style:none;margin:0;padding:0;">
                {aboutChildren.map((child) => (
                  <li><a href={child.url}>{child.label}</a></li>
                ))}
              </ul>
            </NavDropdown>
          )}
          {blogItem && (
            <NavDropdown
              client:load
              label={i18n(blogItem.lang_key)}
              href={resolveUrl(blogItem.url)}
              identifier="blog"
              classes={{
                menuItem: styles.menuItem,
                menuItemOpen: styles['menuItem--open'],
                menuLink: styles.menuLink,
                dropdownMenu: styles.dropdownMenu,
                dropdownMenuOpen: styles['dropdownMenu--open'],
              }}
            >
              <ul style="list-style:none;margin:0;padding:0;">
                {blogChildren.map((child) => (
                  <li><a href={child.url}>{child.label}</a></li>
                ))}
              </ul>
            </NavDropdown>
          )}
          {loginItem && !isDisabledForDocs(loginItem) && (
            <li class={`${styles.menuItem} login-item`}>
              <a class={styles.menuLink} href={resolveUrl(loginItem.url)}>
                <span class="menu-text">{i18n(loginItem.lang_key)}</span>
              </a>
            </li>
          )}
          {getStartedItem && (
            <li class={`${styles.menuItem} get-started-item`}>
              <a class={styles.btnGradient} href={resolveUrl(getStartedItem.url)}>
                <span class={styles.btnGradient__full}>{i18n('get_started_free')}</span>
                <span class={styles.btnGradient__short}>{i18n('free_trial')}</span>
              </a>
            </li>
          )}
        </ul>
      </div>

      {/* Mobile row */}
      <div class={styles.mobileRow}>
        <a href="/" class="header__mobileLogoLink">
          <img
            src={mobileLogoUrl}
            srcset={mobileLogoSrcset}
            class={styles.mobileLogo}
            alt="Datadog Logo"
            width="157"
            height="40"
          />
        </a>
        <MobileNav
          client:load
          classes={{ hamburger: styles.hamburger, hamburgerOpen: styles['hamburger--open'], hamburgerBar: styles.hamburgerBar }}
          quicknav={mobileNavQuicknav}
          search={mobileNavSearch}
          items={mobileItems}
          categories={mobileCategoriesData}
        />
      </div>
    </div>
  </nav>
</div>

<HeaderScroll />
