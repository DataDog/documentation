---
import styles from "./Header.module.css";
import NavDropdown from "./NavDropdown.tsx";
import ProductMegaMenu from "./ProductMegaMenu.tsx";
import LogoDownloadPanel from "./LogoDownloadPanel.astro";
import HeaderScroll from "./HeaderScroll.astro";
import MobileNav, {
  type MobileNavLabels,
} from "@components/MobileNav/MobileNav.tsx";
import { classListFactory } from "@lib/cssUtils/classListFactory.ts";
import { getHeaderData } from "@lib/componentUtils/menuData.ts";
import { i18n } from "@lib/i18n/i18n";
import { IMAGES_URL } from "@config/images.ts";

const cl = classListFactory(styles);

const header = getHeaderData();

// TODO: replace hardcoded English with i18n() once authoritative translation
// keys exist for these strings in the Hugo i18n bundle.
const mobileNavSearch = { placeholder: "Search", ariaLabel: "Search" };
const mobileNavLabels: MobileNavLabels = {
  "Toggle navigation": "Toggle navigation",
  home: i18n("home"),
  docs: i18n("docs") || "Docs",
  api: i18n("api"),
};

const bitsLogoUrl = `${IMAGES_URL}/img/dd_logo_n_70x75.png?ch=Width,DPR&fit=max&auto=format&w=70&h=75`;
const textLogoUrl = `${IMAGES_URL}/img/dd-logo-n-200.png?ch=Width,DPR&fit=max&auto=format&h=14&auto=format&w=807`;
const mobileLogoUrl = `${IMAGES_URL}/img/datadog_rbg_n_2x.png`;
const mobileLogoSrcset = `${mobileLogoUrl} 1x, ${mobileLogoUrl}?dpr=2 2x`;
---

<div class={`${cl("header__wrapper")} main-nav-wrapper`}>
  <nav class={`${cl("header__nav")} main-nav`}>
    <div class={cl("header__container")}>
      {/* Desktop layout */}
      <div class={cl("header__desktop")}>
        <ul class={`${cl("header__left-list")} main-left`}>
          {
            header.product && (
              <ProductMegaMenu
                client:load
                labels={{ trigger: header.product.label, pricing: i18n("view_pricing"), hype: i18n("product_hype") }}
                hrefs={{ product: header.product.href, pricing: `${import.meta.env.SITE}/pricing/` }}
                categories={header.product.megaCategories}
                svgs={{ carrot: header.product.carrotSvg }}
              />
            )
          }

          {
            header.simpleLeft.map((item) => (
              <li class={`${cl("header__menu-item")} ${item.identifier}-item`}>
                <a
                  class={`${cl("header__menu-link")} ${item.identifier}-menu`}
                  href={item.href}
                >
                  <span class="menu-text">{item.label}</span>
                </a>
              </li>
            ))
          }

          {
            header.solutions && (
              <NavDropdown
                client:load
                labels={{ trigger: header.solutions.label }}
                href={header.solutions.href}
                identifier="solutions"
                isSolutions={true}
              >
                <div class={cl("header__solutions-grid")}>
                  {header.solutions.columns.map((col) => (
                    <div class={cl("header__solutions-column")}>
                      <p class={cl("header__solutions-header")}>{col.label}</p>
                      <ul class={cl("header__solutions-list")}>
                        {col.items.map((item) => (
                          <li>
                            <a href={item.url}>
                              <span class={cl("header__menu-text")}>
                                {item.label}
                              </span>
                            </a>
                          </li>
                        ))}
                      </ul>
                    </div>
                  ))}
                </div>
              </NavDropdown>
            )
          }
        </ul>

        {/* Logo */}
        <div class="header__logo-slot">
          <a href="/" class={`${cl("header__logo-column")} js-logo-download`}>
            <img
              height="75"
              class={cl("header__logo-bits")}
              src={bitsLogoUrl}
              srcset={`${bitsLogoUrl} 1x, ${bitsLogoUrl}&dpr=2 2x`}
              alt="Datadog"
            />
            <img
              class={cl("header__logo-text")}
              height="14"
              src={textLogoUrl}
              srcset={`${textLogoUrl} 1x, ${textLogoUrl}&dpr=2 2x`}
              alt="Datadog"
            />
            <LogoDownloadPanel />
          </a>
        </div>

        <ul class={`${cl("header__right-list")} main-right`}>
          {
            header.about && (
              <NavDropdown
                client:load
                labels={{ trigger: header.about.label }}
                href={header.about.href}
                identifier="about"
              >
                <ul style="list-style:none;margin:0;padding:0;">
                  {header.about.children.map((child) => (
                    <li>
                      <a href={child.href}>{child.label}</a>
                    </li>
                  ))}
                </ul>
              </NavDropdown>
            )
          }
          {
            header.blog && (
              <NavDropdown
                client:load
                labels={{ trigger: header.blog.label }}
                href={header.blog.href}
                identifier="blog"
              >
                <ul style="list-style:none;margin:0;padding:0;">
                  {header.blog.children.map((child) => (
                    <li>
                      <a href={child.href}>{child.label}</a>
                    </li>
                  ))}
                </ul>
              </NavDropdown>
            )
          }
          {
            header.login && (
              <li class={`${cl("header__menu-item")} login-item`}>
                <a class={cl("header__menu-link")} href={header.login.href}>
                  <span class="menu-text">{header.login.label}</span>
                </a>
              </li>
            )
          }
          {
            header.getStarted && (
              <li class={`${cl("header__menu-item")} get-started-item`}>
                <a
                  class={cl("header__btn-gradient")}
                  href={header.getStarted.href}
                >
                  <span class={cl("header__btn-gradient-full")}>
                    {i18n("get_started_free")}
                  </span>
                  <span class={cl("header__btn-gradient-short")}>
                    {i18n("free_trial")}
                  </span>
                </a>
              </li>
            )
          }
        </ul>
      </div>

      {/* Mobile row */}
      <div class={cl("header__mobile-row")}>
        <a href="/" class="header__mobile-logo-link">
          <img
            src={mobileLogoUrl}
            srcset={mobileLogoSrcset}
            class={cl("header__mobile-logo")}
            alt="Datadog Logo"
            width="157"
            height="40"
          />
        </a>
        <MobileNav
          client:load
          search={mobileNavSearch}
          items={header.mobileItems}
          categories={header.mobileCategories}
          labels={mobileNavLabels}
        />
      </div>
    </div>
  </nav>
</div>

<HeaderScroll />
