---
import ApiMethodBadge from "@components/ApiMethodBadge/ApiMethodBadge.astro";
import Alert from "@components/Alert/Alert.astro";
import ApiSchemaTable from "@components/ApiSchemaTable/ApiSchemaTable.astro";
import ApiResponse from "@components/ApiResponse/ApiResponse.astro";
import ApiCodeExample from "@components/ApiCodeExample/ApiCodeExample.astro";
import ApiRequestBodyTabs from "@components/ApiRequestBodyTabs/ApiRequestBodyTabs.astro";
import type { SchemaField } from "@lib/api/schemas/schemaField";
import type { ResponseData } from "@components/ApiResponse/ApiResponse.astro";
import type { CodeExampleSet } from "@components/ApiCodeExample/ApiCodeExample.astro";
import { getDefaultRegions } from "@lib/api/regionResolver";
import { renderMarkdownInline } from "@lib/api/markdownRenderer";
import styles from "./ApiEndpoint.module.css";
import { classListFactory } from "@lib/cssUtils/classListFactory";
import { i18n } from "@lib/i18n/i18n";

const allRegions = getDefaultRegions();
const cl = classListFactory(styles);

interface EndpointData {
  operationId: string;
  summary: string;
  slug: string;
  method: string;
  path: string;
  description: string;
  version: "v1" | "v2";
  deprecated: boolean;
  unstable: boolean;
  unstableMessage?: string;
  newerVersionUrl?: string;
  permissions?: string[];
  oauthScopes?: string[];
  regionUrls?: Record<string, string>;
  pathParams?: SchemaField[];
  queryParams?: SchemaField[];
  headerParams?: SchemaField[];
  requestBody?: {
    required: boolean;
    description?: string;
    schema: SchemaField[];
    examples: Array<{ name: string; value: string }>;
  };
  responses: ResponseData[];
  codeExamples: CodeExampleSet[];
}

interface Props {
  data: string; // JSON string of EndpointData
}

const { data: dataJson } = Astro.props;

let ep: EndpointData | null = null;
try {
  ep = JSON.parse(dataJson);
} catch {
  // invalid JSON
}

const hasParams =
  ep &&
  ((ep.pathParams && ep.pathParams.length > 0) ||
    (ep.queryParams && ep.queryParams.length > 0) ||
    (ep.headerParams && ep.headerParams.length > 0));
---

{
  ep && (
    <section
      id={ep.slug}
      class={cl("api-endpoint")}
      data-operation-id={ep.operationId}
    >
      {/* Status alerts */}
      {/* TODO: translate the deprecation/unstable/region-not-supported messages,
        permissions label, "Request Body" heading, and "(required)/(optional)"
        markers once authoritative translation keys exist in the Hugo i18n
        bundle. */}
      {ep.deprecated && (
        <Alert level="warning">
          This endpoint is deprecated.
          {ep.newerVersionUrl && (
            <>
              {" "}
              <a href={ep.newerVersionUrl}>Use the newer version.</a>
            </>
          )}
        </Alert>
      )}
      {ep.unstable && !ep.deprecated && (
        <Alert level="warning">
          <Fragment
            set:html={renderMarkdownInline(
              ep.unstableMessage ??
                "This endpoint is unstable and may change without notice.",
            )}
          />
        </Alert>
      )}

      <div class={cl("api-endpoint__url-line")}>
        <ApiMethodBadge method={ep.method} />
        {allRegions.map((region) => {
          const url = ep.regionUrls?.[region.key];
          return url ? (
            <code class={cl("api-endpoint__path")} data-region={region.key}>
              {url}
            </code>
          ) : (
            <code
              class={cl(
                "api-endpoint__path",
                "api-endpoint__path--unsupported",
              )}
              data-region={region.key}
            >
              Not supported in the {region.label} region
            </code>
          );
        })}
      </div>

      {/* Description — rendered as slot content from the parent page */}
      {ep.description && <h3>{i18n("overview")}</h3>}
      <slot />

      {/* Permissions */}
      {ep.permissions && ep.permissions.length > 0 && (
        <div class={cl("api-endpoint__permissions")}>
          <strong>Permissions: </strong>
          <code>{ep.permissions.join(", ")}</code>
        </div>
      )}

      {/* OAuth scopes */}
      {ep.oauthScopes && ep.oauthScopes.length > 0 && (
        <div class={cl("api-endpoint__permissions")}>
          <p>
            OAuth apps require the <code>{ep.oauthScopes.join(", ")}</code>{" "}
            authorization scope to access this endpoint.
          </p>
        </div>
      )}

      {/* Arguments */}
      {hasParams && (
        <div class={cl("api-endpoint__section")}>
          <h3>{i18n("arguments")}</h3>
          {ep.pathParams && ep.pathParams.length > 0 && (
            <ApiSchemaTable fields={ep.pathParams} />
          )}
          {ep.queryParams && ep.queryParams.length > 0 && (
            <ApiSchemaTable fields={ep.queryParams} />
          )}
          {ep.headerParams && ep.headerParams.length > 0 && (
            <ApiSchemaTable fields={ep.headerParams} />
          )}
        </div>
      )}

      {/* Request Body */}
      {ep.requestBody && (
        <div class={cl("api-endpoint__section")}>
          <h3>
            Request Body {ep.requestBody.required ? "(required)" : "(optional)"}
          </h3>
          {ep.requestBody.description && (
            <p set:html={renderMarkdownInline(ep.requestBody.description)} />
          )}
          <ApiRequestBodyTabs
            schema={ep.requestBody.schema}
            examples={ep.requestBody.examples}
          />
        </div>
      )}

      {/* Response */}
      {ep.responses.length > 0 && <ApiResponse responses={ep.responses} />}

      {/* Code Examples */}
      {ep.codeExamples.length > 0 && (
        <ApiCodeExample examples={ep.codeExamples} />
      )}
    </section>
  )
}
