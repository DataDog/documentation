---
import HttpMethodBadge from '../HttpMethodBadge/HttpMethodBadge.astro';
import ApiStatusAlert from '../ApiStatusAlert/ApiStatusAlert.astro';
import { SchemaTable } from '../SchemaTable/SchemaTable';
import { ApiResponse } from '../ApiResponse/ApiResponse';
import { ApiCodeExample } from '../ApiCodeExample/ApiCodeExample';
import { RequestBodyTabs } from '../RequestBodyTabs/RequestBodyTabs';
import type { SchemaField } from '../SchemaTable/SchemaTable';
import type { ResponseData } from '../ApiResponse/ApiResponse';
import type { CodeExampleSet } from '../ApiCodeExample/ApiCodeExample';
import styles from './ApiEndpoint.module.css';

interface EndpointData {
  operationId: string;
  summary: string;
  slug: string;
  method: string;
  path: string;
  description: string;
  version: 'v1' | 'v2';
  deprecated: boolean;
  unstable: boolean;
  unstableMessage?: string;
  newerVersionUrl?: string;
  permissions?: string[];
  oauthScopes?: string[];
  regionUrls?: Record<string, string>;
  pathParams?: SchemaField[];
  queryParams?: SchemaField[];
  headerParams?: SchemaField[];
  requestBody?: {
    required: boolean;
    description?: string;
    schema: SchemaField[];
    examples: Array<{ name: string; value: string }>;
  };
  responses: ResponseData[];
  codeExamples: CodeExampleSet[];
}

interface Props {
  data: string; // JSON string of EndpointData
}

const { data: dataJson } = Astro.props;

let ep: EndpointData | null = null;
try {
  ep = JSON.parse(dataJson);
} catch {
  // invalid JSON
}

const hasParams = ep && (
  (ep.pathParams && ep.pathParams.length > 0) ||
  (ep.queryParams && ep.queryParams.length > 0) ||
  (ep.headerParams && ep.headerParams.length > 0)
);
---

{ep && (
  <section class={styles.endpoint} data-testid="api-endpoint" data-operation-id={ep.operationId}>
    {/* Status alerts */}
    {ep.deprecated && (
      <ApiStatusAlert type="deprecated" newerVersionUrl={ep.newerVersionUrl} />
    )}
    {ep.unstable && !ep.deprecated && (
      <ApiStatusAlert type="unstable" message={ep.unstableMessage} />
    )}

    {/* Heading + method badge + path */}
    <h2 id={ep.slug} class={styles.heading}>
      {ep.summary}
      {ep.version && <span class={styles.versionBadge}>{ep.version === 'v2' ? 'v2 (latest)' : ep.version}</span>}
    </h2>
    <div class={styles.urlLine}>
      <HttpMethodBadge method={ep.method} />
      <code class={styles.path}>{ep.regionUrls?.['us1'] ?? ep.regionUrls?.[Object.keys(ep.regionUrls ?? {})[0]] ?? ep.path}</code>
    </div>

    {/* Description — rendered as slot content from Markdoc */}
    {ep.description && <h3>Overview</h3>}
    <slot />

    {/* Permissions */}
    {ep.permissions && ep.permissions.length > 0 && (
      <div class={styles.permissions}>
        <strong>Permissions: </strong>
        <code>{ep.permissions.join(', ')}</code>
      </div>
    )}

    {/* OAuth scopes */}
    {ep.oauthScopes && ep.oauthScopes.length > 0 && (
      <div class={styles.permissions}>
        <p>OAuth apps require the <code>{ep.oauthScopes.join(', ')}</code> authorization scope to access this endpoint.</p>
      </div>
    )}

    {/* Arguments */}
    {hasParams && (
      <div class={styles.section}>
        <h3>Arguments</h3>
        {ep.pathParams && ep.pathParams.length > 0 && (
          <SchemaTable client:load fields={ep.pathParams} />
        )}
        {ep.queryParams && ep.queryParams.length > 0 && (
          <SchemaTable client:load fields={ep.queryParams} />
        )}
        {ep.headerParams && ep.headerParams.length > 0 && (
          <SchemaTable client:load fields={ep.headerParams} />
        )}
      </div>
    )}

    {/* Request Body */}
    {ep.requestBody && (
      <div class={styles.section}>
        <h3>Request Body {ep.requestBody.required ? '(required)' : '(optional)'}</h3>
        {ep.requestBody.description && (
          <p set:html={ep.requestBody.description} />
        )}
        <RequestBodyTabs
          client:load
          schema={ep.requestBody.schema}
          examples={ep.requestBody.examples}
        />
      </div>
    )}

    {/* Response */}
    {ep.responses.length > 0 && (
      <ApiResponse client:load responses={ep.responses} />
    )}

    {/* Code Examples */}
    {ep.codeExamples.length > 0 && (
      <ApiCodeExample client:load examples={ep.codeExamples} />
    )}

    <hr class={styles.divider} />
  </section>
)}
