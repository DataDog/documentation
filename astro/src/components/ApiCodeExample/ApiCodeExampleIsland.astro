---
import ApiCodeExample from './ApiCodeExample.astro';
import type { CodeExampleSet } from './ApiCodeExample.astro';

interface Props {
  examples: string; // JSON string of CodeExampleSet[]
}

const { examples: examplesJson } = Astro.props;

let parsedExamples: CodeExampleSet[] = [];
try {
  parsedExamples = JSON.parse(examplesJson);
} catch {
  // fallback
}
---

<ApiCodeExample examples={parsedExamples} />
