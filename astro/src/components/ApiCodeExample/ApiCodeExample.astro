---
import TabsIsland from '../Tabs/TabsIsland.astro';
import Tab from '../Tab/Tab.astro';
import CodeBlockIsland from '../CodeBlock/CodeBlockIsland.astro';
import styles from './ApiCodeExample.module.css';
import { classListFactory } from '../../utils/classListFactory';

const cl = classListFactory(styles);

export interface CodeExampleEntry {
  description: string;
  code: string;
  syntax: string;
  /** If present, render one code block per region. Only the variant matching the active region is visible. */
  regionVariants?: Record<string, { code: string }>;
}

export interface CodeExampleSet {
  language: string;
  label: string;
  entries: CodeExampleEntry[];
}

interface Props {
  examples: CodeExampleSet[];
}

const { examples } = Astro.props;
---

{examples.length > 0 && (
  <div class={cl('api-code-example')}>
    <h3 class={cl('api-code-example__heading')}>Code Example</h3>

    <TabsIsland variant="pills">
      {examples.map((ex) => (
        <Tab label={ex.label}>
          {ex.entries.length === 1 ? (
            ex.entries[0].regionVariants ? (
              Object.entries(ex.entries[0].regionVariants).map(([regionKey, variant]) => (
                <div data-region={regionKey} class={cl('api-code-example__code-block')}>
                  <CodeBlockIsland content={variant.code} language={ex.entries[0].syntax} />
                </div>
              ))
            ) : (
              <div class={cl('api-code-example__code-block')}>
                <CodeBlockIsland content={ex.entries[0].code} language={ex.entries[0].syntax} />
              </div>
            )
          ) : (
            ex.entries.map((entry, i) => (
              <details class={cl('api-code-example__accordion')} open={i === 0}>
                <summary class={cl('api-code-example__accordion-header')}>
                  <svg class={cl('api-code-example__accordion-icon')} width="10" height="10" viewBox="0 0 10 10">
                    <path d="M3 1 L7 5 L3 9" fill="none" stroke="currentColor" stroke-width="1.5" />
                  </svg>
                  <span>{entry.description}</span>
                </summary>
                {entry.regionVariants ? (
                  Object.entries(entry.regionVariants).map(([regionKey, variant]) => (
                    <div data-region={regionKey} class={cl('api-code-example__code-block')}>
                      <CodeBlockIsland content={variant.code} language={entry.syntax} />
                    </div>
                  ))
                ) : (
                  <div class={cl('api-code-example__code-block')}>
                    <CodeBlockIsland content={entry.code} language={entry.syntax} />
                  </div>
                )}
              </details>
            ))
          )}
        </Tab>
      ))}
    </TabsIsland>
  </div>
)}
