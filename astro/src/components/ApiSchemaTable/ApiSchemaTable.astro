---
import type { SchemaField } from '@lib/api/schemas/schemaField';
import { ApiSchemaTableNav } from './ApiSchemaTableNav';
import {
  renderFieldsHtml,
  anyFieldExpandable,
} from './renderFieldsHtml';
import styles from './ApiSchemaTable.module.css';
import { classListFactory } from '@utils/classListFactory';
import { generateElementId } from '@utils/generateElementId';

const cl = classListFactory(styles);

interface Props {
  fields: SchemaField[] | string;
  title?: string;
  showExpandAll?: boolean;
}

const { fields: fieldsProp, title, showExpandAll = true } = Astro.props;

let fields: SchemaField[] = [];
if (typeof fieldsProp === 'string') {
  try {
    fields = JSON.parse(fieldsProp);
  } catch {
    // If parsing fails, render nothing
  }
} else {
  fields = fieldsProp;
}

const tableId = generateElementId('schema-table');
const expandAllId = `${tableId}-expand-all`;
const showToolbar = showExpandAll && anyFieldExpandable(fields);

const rowsHtml = renderFieldsHtml(fields, cl);
---

<div id={tableId} class="schema-table">
  {title && <h4>{title}</h4>}
  {showToolbar && (
    <div class={cl('schema-table__toolbar')}>
      <button id={expandAllId} type="button" class={cl('schema-table__expand-all')}>
        <span class={cl('schema-table__expand-all-label', 'schema-table__expand-all-label--expand')}>
          Expand All
        </span>
        <span class={cl('schema-table__expand-all-label', 'schema-table__expand-all-label--collapse')} hidden>
          Collapse All
        </span>
      </button>
    </div>
  )}
  <div class={cl('schema-table__table')}>
    <div class={cl('schema-table__columns')}>
      <div class={cl('schema-table__columns-name')}>Name</div>{' '}
      <div class={cl('schema-table__columns-type')}>Type</div>{' '}
      <div class={cl('schema-table__columns-description')}>Description</div>
    </div>
    <Fragment set:html={rowsHtml} />
  </div>
  <ApiSchemaTableNav
    client:idle
    externalContext={{
      scope: tableId,
      entries: showToolbar
        ? { tableEl: tableId, expandAllEl: expandAllId }
        : { tableEl: tableId },
    }}
  />
</div>
