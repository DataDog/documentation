---
import ApiSchemaTable from './ApiSchemaTable.astro';
import type { SchemaField } from '@lib/api/schemas/schemaField';

interface Props {
  fields: string; // JSON string of SchemaField[]
  title?: string;
  showExpandAll?: boolean;
}

const { fields: fieldsJson, title, showExpandAll } = Astro.props;

let parsedFields: SchemaField[] = [];
try {
  parsedFields = JSON.parse(fieldsJson);
} catch {
  // fallback
}
---

<ApiSchemaTable fields={parsedFields} title={title} showExpandAll={showExpandAll} />
