---
import { renderMarkdownInline } from '@lib/api/markdownRenderer';
import styles from './ApiStatusAlert.module.css';
import { classListFactory } from '@utils/classListFactory';

interface Props {
  type: 'deprecated' | 'unstable' | 'beta';
  newerVersionUrl?: string;
  message?: string;
}

const { type, newerVersionUrl, message } = Astro.props;
const cl = classListFactory(styles);

const defaults: Record<string, { label: string; defaultMessage: string }> = {
  deprecated: {
    label: 'Deprecated',
    defaultMessage: 'This endpoint is deprecated.',
  },
  unstable: {
    label: 'Unstable',
    defaultMessage: 'This endpoint is unstable and may change without notice.',
  },
  beta: {
    label: 'Beta',
    defaultMessage: 'This endpoint is in beta and may change.',
  },
};

const config = defaults[type];
const displayMessage = message || config.defaultMessage;
---

<div
  class={cl('api-status-alert', `api-status-alert--${type}`)}
  role="alert"
>
  <span class={cl('api-status-alert__label')}>{config.label}</span>
  <span class={cl('api-status-alert__message')}>
    <Fragment set:html={renderMarkdownInline(displayMessage)} />
    {newerVersionUrl && type === 'deprecated' && (
      <a href={newerVersionUrl} class={cl('api-status-alert__link')}>Use the newer version.</a>
    )}
  </span>
</div>
