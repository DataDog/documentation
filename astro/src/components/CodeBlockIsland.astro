---
import { CodeBlock } from './CodeBlock';
import { codeToHtml } from 'shiki';
import datadogTheme from '../styles/shiki-datadog';

interface Props {
  content: string;
  language?: string;
  filename?: string;
  wrap?: boolean;
  collapsible?: boolean;
  disable_copy?: boolean;
}

const {
  content,
  language,
  filename,
  wrap = false,
  collapsible = false,
  disable_copy = false,
} = Astro.props;

let highlightedCode = '';
if (content) {
  try {
    highlightedCode = await codeToHtml(content, {
      lang: language || 'text',
      theme: datadogTheme,
    });
  } catch {
    // Unknown language — fall back to plain text display
  }
}
---

<CodeBlock
  client:load
  content={content}
  language={language}
  highlightedCode={highlightedCode}
  filename={filename}
  wrap={wrap}
  collapsible={collapsible}
  disableCopy={disable_copy}
/>
