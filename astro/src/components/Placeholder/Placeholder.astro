---
import styles from './Placeholder.module.css';

interface Props {
  name: string;
  class?: string;
}

const { name, class: className } = Astro.props;
const rootClass = ['placeholder', styles.placeholder, className].filter(Boolean).join(' ');
---

<div class={rootClass} data-placeholder-name={name}>
  <span>{name}</span>
</div>
