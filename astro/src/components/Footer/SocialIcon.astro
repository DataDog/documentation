---
/**
 * Renders a websites-modules iconfont icon for social links via <i class="icon-{name}">.
 * Matches Hugo's approach of using the shared iconfont rather than inlining SVGs.
 */
interface Props {
  name: string;
  class?: string;
  size?: string;
}

const { name, class: className, size } = Astro.props;
const style = size ? `font-size:${size}` : undefined;
---

<i class={`icon-${name} social-icon ${className ?? ''}`} style={style} aria-hidden="true" />

<style is:global>
  .social-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
  }
</style>
