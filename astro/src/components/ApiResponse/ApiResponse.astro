---
import Tabs from "@components/Tabs/Tabs.astro";
import TabPanel from "@components/Tab/TabPanel.astro";
import CodeBlock from "@components/CodeBlock/CodeBlock.astro";
import ApiSchemaTable from "@components/ApiSchemaTable/ApiSchemaTable.astro";
import type { SchemaField } from "@lib/api/schemas/schemaField";
import { renderMarkdownInline } from "@lib/api/markdownRenderer";
import styles from "./ApiResponse.module.css";
import { classListFactory } from "@lib/cssUtils/classListFactory";
import { generateElementId } from "@lib/componentUtils/generateElementId";
import { i18n } from "@lib/i18n/i18n";

const cl = classListFactory(styles);

interface Example {
  name: string;
  value: string;
}

export interface ResponseData {
  statusCode: string;
  description?: string;
  schema?: SchemaField[];
  examples?: Example[];
}

interface Props {
  responses: ResponseData[];
}

const { responses } = Astro.props;

const outerGroupId = generateElementId("api-response");
const outerLabels = responses.map((r) => r.statusCode);
const outerPanelIds = responses.map((_, i) => `${outerGroupId}-panel-${i}`);
const innerPanelIds = responses.map((_, i) => [
  `${outerGroupId}-model-${i}`,
  `${outerGroupId}-example-${i}`,
]);
---

{
  responses.length > 0 && (
    <div class={cl("api-response")}>
      <h3 class={cl("api-response__heading")}>{i18n("response")}</h3>

      <Tabs
        id={outerGroupId}
        variant="pills"
        labels={outerLabels}
        panelIds={outerPanelIds}
      >
        {responses.map((r, i) => {
          const hasSchema = (r.schema?.length ?? 0) > 0;
          const hasExamples = (r.examples?.length ?? 0) > 0;
          const showInnerTabs = hasSchema && hasExamples;
          return (
            <TabPanel id={outerPanelIds[i]} isActive={i === 0}>
              <div
                class={`api-response__panel api-response__panel--${r.statusCode}`}
              >
                {r.description && (
                  <p
                    class={cl("api-response__description")}
                    set:html={renderMarkdownInline(r.description)}
                  />
                )}

                {showInnerTabs && (
                  <Tabs
                    id={`${outerGroupId}-inner-${i}`}
                    variant="pills"
                    labels={[i18n("model"), i18n("example")]}
                    panelIds={innerPanelIds[i]}
                  >
                    <TabPanel id={innerPanelIds[i][0]} isActive>
                      <ApiSchemaTable fields={r.schema!} />
                    </TabPanel>
                    <TabPanel id={innerPanelIds[i][1]}>
                      {r.examples!.map((ex) => (
                        <div class={cl("api-response__example")}>
                          <CodeBlock content={ex.value} language="json" />
                        </div>
                      ))}
                    </TabPanel>
                  </Tabs>
                )}

                {!showInnerTabs && hasSchema && (
                  <ApiSchemaTable fields={r.schema!} />
                )}

                {!showInnerTabs &&
                  hasExamples &&
                  r.examples!.map((ex) => (
                    <div class={cl("api-response__example")}>
                      <CodeBlock content={ex.value} language="json" />
                    </div>
                  ))}
              </div>
            </TabPanel>
          );
        })}
      </Tabs>
    </div>
  )
}
