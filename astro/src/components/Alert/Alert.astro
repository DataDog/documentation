---
import styles from './Alert.module.css';

interface Props {
  type?: 'info' | 'danger' | 'warning' | 'tip';
}

const labels: Record<string, string> = {
  info: 'Note',
  danger: 'Caution',
  warning: 'Warning',
  tip: 'Tip',
};

const { type = 'info' } = Astro.props;
const label = labels[type] ?? type;
---

<div class:list={['alert', `alert--${type}`, styles.alert, styles[`alert--${type}`]]} data-alert-type={type}>
  <strong class={`alert__label ${styles['alert__label']}`}>{label}</strong>
  <slot />
</div>
