---
interface Props {
  method: string;
}

const { method } = Astro.props;
const normalized = method.toLowerCase();
const label = method.toUpperCase();

import styles from './ApiMethodBadge.module.css';
---

<span
  class:list={['api-method-badge', `api-method-badge--${normalized}`, styles.badge, styles[`badge--${normalized}`]]}
  data-method={normalized}
  data-testid="api-method-badge"
>
  {label}
</span>
