---
import * as cheerio from 'cheerio';
import { TabsNav } from './TabsNav';
import styles from './Tabs.module.css';
import { classListFactory } from '../../utils/classListFactory';

const cl = classListFactory(styles);

const slotHtml = await Astro.slots.render('default');
const $ = cheerio.load(slotHtml, null, false);

const tabs = $('[data-tab-label]')
  .map((_, el) => ({
    label: $(el).attr('data-tab-label') ?? '',
    content: $(el).html() ?? '',
  }))
  .get();

const groupId = `tabs-${crypto.randomUUID().slice(0, 8)}`;
const panelIds = tabs.map((_, i) => `${groupId}-panel-${i}`);
---

<div class={cl('tabs')}>
  <TabsNav client:load labels={tabs.map(t => t.label)} panelIds={panelIds} />

  {tabs.map((tab, i) => (
    <div
      id={panelIds[i]}
      role="tabpanel"
      class={i === 0 ? cl('tabs__panel', 'tabs__panel--active') : cl('tabs__panel')}
      hidden={i !== 0}
      set:html={tab.content}
    />
  ))}
</div>
