---
import { getCollection } from 'astro:content';
import DocsLayout from '../../../layouts/DocsLayout.astro';
import Alert from '../../../components/Alert/Alert.astro';

const docs = await getCollection('docs');
const components = docs
  .filter((entry) => entry.id.startsWith('test_pages/components/'))
  .sort((a, b) => a.data.title.localeCompare(b.data.title));
---

<DocsLayout title="Test Pages">
  <div class="docs-page">
    <div class="prose">
      <h1>Test Pages</h1>

      <Alert level="warning">
        To verify component hydration, <strong>you must build these pages with <code>npm run build</code>, not <code>npm run dev</code>!</strong>
      </Alert>

      <h2>Integration</h2>
      <table>
        <thead>
          <tr>
            <th>Page</th>
            <th>Purpose</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td><a href="/docs/test_pages/integration/typography/">Typography</a></td>
            <td>Verify vanilla Markdown elements such as headings and links.</td>
          </tr>
          <tr>
            <td><a href="/docs/test_pages/integration/nested-content/">Nested content</a></td>
            <td>Verify the rendering and hydration of components nested inside other components, such as a code block inside a tab.</td>
          </tr>
        </tbody>
      </table>

      <h2>Components</h2>
      <p><a href="/api/latest/">&larr; API docs</a></p>
      <table>
        <thead>
          <tr>
            <th>Component</th>
            <th>Type</th>
            <th>Architecture</th>
          </tr>
        </thead>
        <tbody>
          {components.map((entry) => (
            <tr>
              <td><a href={`/docs/${entry.id}/`}>{entry.data.title}</a></td>
              <td>{entry.data.type ?? ''}</td>
              <td>{entry.data.description ?? ''}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</DocsLayout>

<style>
  .docs-page {
    max-width: 960px;
    margin: 0 auto;
    padding: var(--space-lg);
  }

  table {
    width: 100%;
    border-collapse: collapse;
  }

  th, td {
    text-align: left;
    padding: var(--space-xs) var(--space-sm);
    border-bottom: 1px solid var(--color-surface-border);
    vertical-align: top;
  }

  th {
    font-weight: 600;
    border-bottom-width: 2px;
  }

  td:first-child {
    white-space: nowrap;
  }

  table a {
    text-decoration: none;
  }
</style>
