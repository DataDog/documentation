---
import ApiLayout from '../../../../layouts/ApiLayout.astro';
import ApiMethodBadge from '../../../../components/ApiMethodBadge/ApiMethodBadge.astro';
import ApiStatusAlert from '../../../../components/ApiStatusAlert/ApiStatusAlert.astro';
import { getCategoriesView, getCategoryViewBySlug } from '../../../../data/api/viewsBuilder';
import { renderMarkdown } from '../../../../data/api/markdownRenderer';
import { getApiPageTitle } from '../../../../data/api/pageTitleBuilder';
import { LOCALES, parseLangParam, localizedHref } from '../../../../lib/i18n/locale';
import { mdToMetaDescription } from '../../../../lib/seo';
import { i18n } from '../../../../lib/i18n/i18n';
import type { GetStaticPaths, GetStaticPathsResult } from 'astro';

export const getStaticPaths: GetStaticPaths = async () => {
  const paths: GetStaticPathsResult = [];
  for (const lang of LOCALES) {
    for (const cat of await getCategoriesView(lang)) {
      paths.push({
        params: {
          lang: lang === 'en' ? undefined : lang,
          category: cat.slug,
        },
      });
    }
  }
  return paths;
};

const lang = parseLangParam(Astro.params.lang);
if (!lang) {
  return new Response(null, { status: 404 });
}

const slug = Astro.params.category;
if (!slug || typeof slug !== 'string') {
  return new Response(null, { status: 404 });
}

const categories = await getCategoriesView(lang);
const current = await getCategoryViewBySlug(slug, lang);
if (!current) {
  return new Response(null, { status: 404 });
}

const validOpSlugs = current.operations.map((op) => op.slug);
const categoryBaseHref = localizedHref(lang, `/api/latest/${slug}/`);
---

<ApiLayout
  title={`${current.name} - Datadog API`}
  description={mdToMetaDescription(current.description) || `${current.name} endpoints in the Datadog API.`}
  categories={categories}
  currentSlug={slug}
  breadcrumbs={[
    { label: i18n('docs', lang), href: localizedHref(lang, '/') },
    { label: getApiPageTitle('', lang) ?? 'API Reference', href: localizedHref(lang, '/api/latest/') },
    { label: current.name },
  ]}
>
  <h1>{current.name}</h1>
  {current.deprecated && <ApiStatusAlert type="deprecated" />}
  {current.description && (
    <div set:html={renderMarkdown(current.description)} />
  )}
  {current.operations.length > 0 && (
    <ul class="api-category-toc">
      {current.operations.map((op) => (
        <li class="api-category-toc__item">
          <ApiMethodBadge method={op.method} />
          <a href={`${categoryBaseHref}${op.slug}/`} class="api-category-toc__link">
            {op.summary}
          </a>
        </li>
      ))}
    </ul>
  )}
</ApiLayout>

{/*
  Backward-compat hop: links from the Hugo era of the form
  `/api/latest/<cat>/#<op-slug>` should land on the new per-operation page.
  Browsers do not send the hash to the server, so this must run client-side.
*/}
<script is:inline define:vars={{ baseHref: categoryBaseHref, validOpSlugs }}>
  (function () {
    if (!window.location.hash) return;
    const slug = window.location.hash.slice(1);
    if (!slug || !validOpSlugs.includes(slug)) return;
    window.location.replace(baseHref + slug + '/');
  })();
</script>

<style>
  .api-category-toc {
    list-style: none;
    padding: 0;
    margin: var(--space-md) 0 0 0;
  }

  .api-category-toc__item {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-2xs) 0;
  }

  .api-category-toc__link {
    color: var(--color-text);
    text-decoration: none;
  }

  .api-category-toc__link:hover {
    color: var(--color-brand);
    text-decoration: underline;
  }
</style>
