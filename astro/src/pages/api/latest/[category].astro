---
import ApiLayout from '../../../layouts/ApiLayout.astro';
import ApiEndpoint from '../../../components/ApiEndpoint/ApiEndpoint.astro';
import { getApiCategories, getCategoryBySlug } from '../../../data/api/index';
import { getEndpointsForCategory } from '../../../data/api/endpoints';
import { highlightEndpoints } from '../../../data/api/highlight';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = () => {
  const categories = getApiCategories();
  return categories.map((cat) => ({
    params: { category: cat.slug },
  }));
};

const { category: slug } = Astro.params;
if (!slug || typeof slug !== 'string') {
  return new Response(null, { status: 404 });
}

const categories = getApiCategories();
const current = getCategoryBySlug(slug);
if (!current) {
  return new Response(null, { status: 404 });
}

const endpoints = getEndpointsForCategory(slug);
await highlightEndpoints(endpoints);
---

<ApiLayout title={`${current.name} - Datadog API`} categories={categories} currentSlug={slug as string} breadcrumbs={[{ label: 'Docs', href: '/' }, { label: 'API Reference', href: '/api/latest/' }, { label: current.name }]}>
  <h1>{current.name}</h1>
  {current.description && (
    <div set:html={current.description} />
  )}
  {endpoints.map((ep) => (
    <ApiEndpoint data={JSON.stringify(ep)}>
      <Fragment set:html={ep.description} />
    </ApiEndpoint>
  ))}
</ApiLayout>
