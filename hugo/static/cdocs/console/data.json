  "customizationConfig": {
    "traitsById": {
      "api_type": {
        "id": "api_type",
        "type": "text",
        "label": "API",
        "internal_notes": "The instrumentation API type, such as OpenTelemetry API or Datadog native API."
      },
      "database": {
        "id": "database",
        "type": "text",
        "label": "Database"
      },
      "host": {
        "id": "host",
        "type": "text",
        "label": "Host",
        "internal_notes": "Hosting platform, such as AWS or GCP. Can also refer to containers like Kubernetes."
      },
      "host_type": {
        "id": "host_type",
        "type": "text",
        "label": "Host type",
        "internal_notes": "The machine or container type within a given host, such as EC2. Use only as a followup to a `host` selection."
      },
      "lib_src": {
        "id": "lib_src",
        "type": "text",
        "label": "Source",
        "internal_notes": "The source of a software library that the customer is trying to use in their code, such as an SDK. This is most often a package manager like NPM. But it could also have a more general value, like \"CDN\" or \"GitHub\"."
      },
      "mobile_os": {
        "id": "mobile_os",
        "type": "text",
        "label": "OS",
        "internal_notes": "Mobile operating system, such as Android."
      },
      "os": {
        "id": "os",
        "type": "text",
        "label": "OS",
        "internal_notes": "Env operating system, such as Linux or Windows. Can refer to a mobile OS, but `mobile_os` is preferred for lists of mobile-only options."
      },
      "platform": {
        "id": "platform",
        "type": "text",
        "label": "Platform",
        "internal_notes": "The target platform (language, framework, specific env) for a library, SDK, or other third-party entity. Do not use if every option is a pure programming language (Go, Python, etc.) -- use `prog_lang` instead. Re-label to \"Framework\", \"SDK\", etc. if it's more appropriate for your context."
      },
      "product": {
        "id": "product",
        "type": "text",
        "label": "Product",
        "internal_notes": "On pages that support more than one Datadog product, this trait allows the customer to choose one."
      },
      "prog_lang": {
        "id": "prog_lang",
        "type": "text",
        "label": "Programming Language",
        "internal_notes": "Do not use for frameworks like Next or React Native. Instead, use `platform`."
      },
      "protocol": {
        "id": "protocol",
        "type": "text",
        "label": "Protocol",
        "internal_notes": "For example, HTTP, gRPC, or SOCKS."
      },
      "interface": {
        "id": "interface",
        "type": "text",
        "label": "Interface",
        "internal_notes": "The tool through which the user is performing a task or otherwise accessing Datadog features. For example, web UI, API, CLI, or Terraform."
      },
      "runtime": {
        "id": "runtime",
        "type": "text",
        "label": "Runtime",
        "internal_notes": "The runtime environment, such as JVM or GraalVM Native Image. Used when a language has multiple runtime targets."
      },
      "secrets_source": {
        "id": "secrets_source",
        "type": "text",
        "label": "Secrets source",
        "internal_notes": "The location of the user's sensitive information, such as API keys or other credentials. For example, Secrets Management or environment variables."
      },
      "rum_browser_sdk_version": {
        "id": "rum_browser_sdk_version",
        "type": "semver",
        "label": "SDK version",
        "internal_notes": "The customer's version of the RUM browser SDK. Its value should be a semantic version represented in snake case, such as \"1_2_3\", \"lt_1_2_3\", \"gt_1_2_3\", \"lte_1_2_3\", etc."
      },
      "synthetics_variables": {
        "id": "synthetics_variables",
        "type": "text",
        "label": "Synthetics Variables",
        "internal_notes": "The variables available for use in in Synthetic Monitoring test notifications."
      }
    },
