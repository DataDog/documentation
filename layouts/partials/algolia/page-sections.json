{{- /* Creates an algolia json record for each individual section of the given page.

       Sections are derived from:
         1. The "lead" content before the first H2/H3 heading (order -1).
         2. Each H2/H3 heading section (order 0, 1, 2, ...).

       When a section's HTML contains tab-pane blocks (rendered by the tab shortcode
       as div.tab-pane with a title attribute), the section is further split into
       one chunk per tab, using the tab title as a synthetic sub-heading. This avoids
       collapsing tab-structured pages (e.g. profiler/profile_types) into a single blob. */ -}}

{{ $hugo_context := .context }}
{{ $page := .page }}
{{ $title := .title }}
{{ $category := .category }}
{{ $subcategory := .subcategory }}
{{ $rank := .rank }}

{{- /* Emits search records for one HTML block under a given base header at a given order.
       If the block contains tab-panes, emits one record per tab (header = "base - tabTitle"),
       otherwise emits the block as a single (word-chunked) section. */ -}}
{{- define "partials/algolia-section-chunks" -}}
  {{- $hugo_context := .ctx.context -}}
  {{- $page := .ctx.page -}}
  {{- $title := .ctx.title -}}
  {{- $category := .ctx.category -}}
  {{- $subcategory := .ctx.subcategory -}}
  {{- $rank := .ctx.rank -}}
  {{- $order := .order -}}
  {{- $html := .html -}}
  {{- $baseHeader := .header -}}

  {{- $tabRe := `<div[^>]*class="[^"]*tab-pane[^"]*"[^>]*>` -}}
  {{- $tabOpens := findRE $tabRe $html -}}

  {{- /* Guard against nested or multiple tab groups: the tab shortcode emits exactly one
         code-tabs wrapper per group, so a second wrapper after the first tab-pane means the
         flat split would mislabel headers. In that case, skip tab-splitting and index the
         block as a single section (all content is still captured, just not tab-split). */ -}}
  {{- $tabSplit := gt (len $tabOpens) 0 -}}
  {{- if $tabSplit -}}
      {{- $afterFirstPane := index (split $html (index $tabOpens 0)) 1 -}}
      {{- if findRE `<div[^>]*class=['"][^'"]*code-tabs[^'"]*['"]` $afterFirstPane 1 -}}
          {{- $tabSplit = false -}}
      {{- end -}}
  {{- end -}}

  {{- /* Only split genuine {{ tab }} shortcode panes, which always carry a title= attribute.
         Other components reuse the tab-pane class without a title (e.g. the widget API
         model/example toggle); splitting those would create multiple same-header segments
         that collide on objectID. If any matched pane lacks a title, skip tab-splitting. */ -}}
  {{- if $tabSplit -}}
      {{- range $open := $tabOpens -}}
          {{- if not (findRE `<div[^>]*\stitle="` $open) -}}
              {{- $tabSplit = false -}}
          {{- end -}}
      {{- end -}}
  {{- end -}}

  {{- /* Build the list of segments to index. Each segment is a dict with:
           header: display section header
           html:   the HTML block
           tab:    the tab's data-lang ("" for non-tab segments), used for the ?tab= link
           anchor: the heading anchor ("" when there is no enclosing heading) */ -}}
  {{- $baseAnchor := $baseHeader | anchorize -}}
  {{- $segments := slice -}}
  {{- if $tabSplit -}}
      {{- /* Capture any intro content before the first tab, so it isn't dropped. */ -}}
      {{- $preTab := index (split $html (index $tabOpens 0)) 0 -}}
      {{- if gt (len (trim ($preTab | plainify) " \r\n\t")) 2 -}}
          {{- $segments = $segments | append (dict "header" $baseHeader "html" $preTab "tab" "" "anchor" $baseAnchor) -}}
      {{- end -}}
      {{- range $open := $tabOpens -}}
          {{- $after := index (split $html $open) 1 -}}
          {{- $nextOpen := index (findRE $tabRe $after 1) 0 | default "" -}}
          {{- $block := $after -}}
          {{- if $nextOpen -}}
              {{- $block = index (split $after $nextOpen) 0 -}}
          {{- end -}}
          {{- $tabTitle := "" -}}
          {{- if (findRE `title="` $open) -}}
              {{- $tabTitle = (replaceRE `(?s).*?title="([^"]*)".*` "$1" $open) | htmlUnescape | safeHTML -}}
          {{- end -}}
          {{- $tabLang := "" -}}
          {{- if (findRE `data-lang="` $open) -}}
              {{- $tabLang = replaceRE `(?s).*?data-lang="([^"]*)".*` "$1" $open -}}
          {{- end -}}
          {{- $h := $tabTitle -}}
          {{- if and $baseHeader $tabTitle -}}
              {{- $h = print $baseHeader " - " $tabTitle -}}
          {{- else if not $tabTitle -}}
              {{- $h = $baseHeader -}}
          {{- end -}}
          {{- $segments = $segments | append (dict "header" $h "html" $block "tab" $tabLang "anchor" $baseAnchor) -}}
      {{- end -}}
  {{- else -}}
      {{- $segments = $segments | append (dict "header" $baseHeader "html" $html "tab" "" "anchor" $baseAnchor) -}}
  {{- end -}}

  {{- range $segments -}}
      {{- $section_header := .header -}}
      {{- $section_tab := .tab -}}
      {{- $section_anchor := .anchor -}}
      {{- $section_content := .html | plainify | htmlUnescape | safeHTML -}}
      {{- if and (ne $section_header "Further Reading") (ne (trim $section_content " \r\n\t") "") -}}
          {{- $words := split $section_content " " -}}
          {{- $post_len := len $section_content -}}
          {{- if gt $post_len 100000 -}}
              {{- $post_len = 100000 -}}
          {{- end -}}
          {{- $chunked := slice -}}
          {{- range $i := (seq 0 500 $post_len) -}}
              {{- $chunked = $chunked | append (delimit (first 500 (after $i $words)) " ") -}}
          {{- end -}}
          {{- range $i, $c := $chunked -}}
              {{- if gt (len $c) 2 -}}
                  {{- /* objectID keeps using the (possibly combined) section header anchor so
                         IDs stay unique and stable across builds. */ -}}
                  {{- $id_anchor := $section_header | anchorize -}}
                  {{- $hdr := $section_header -}}
                  {{- if $page.Params.exclude_headers_from_search -}}
                      {{- $hdr = "" -}}
                  {{- end -}}
                  {{- $object_id := print $page.File.UniqueID "_" $page.Language.Lang "_" $id_anchor "_" $i "_" $order -}}
                  {{- /* Link target: tab segments open the tab via ?tab=<data-lang> (and scroll
                         to the enclosing heading anchor if present); non-tab segments link to
                         the heading anchor. */ -}}
                  {{- $url_suffix := "" -}}
                  {{- if $section_tab -}}
                      {{- $url_suffix = print "?tab=" $section_tab -}}
                      {{- if $section_anchor -}}
                          {{- $url_suffix = print $url_suffix "#" $section_anchor -}}
                      {{- end -}}
                  {{- else if $section_anchor -}}
                      {{- $url_suffix = print "#" $section_anchor -}}
                  {{- end -}}
                  {{- $full_url := print $page.Permalink $url_suffix -}}
                  {{- $relpermalink := print $page.RelPermalink $url_suffix -}}
                  {{- $hugo_context.Scratch.Add "algoliaindex" (
                      dict "objectID" $object_id
                      "id" $object_id
                      "title" $title
                      "section_header" $hdr
                      "content" $c
                      "type" $page.Type
                      "relpermalink" $relpermalink
                      "distinct_base_url" $page.RelPermalink
                      "full_url" $full_url
                      "language" $page.Language.Lang
                      "category" $category
                      "subcategory" $subcategory
                      "rank" $rank
                      "order" $order
                      "tags" ($page.Params.algolia.tags | default slice)
                  ) -}}
              {{- end -}}
          {{- end -}}
      {{- end -}}
  {{- end -}}
{{- end -}}

{{- define "partials/heading-sections" -}}
  {{- $ctx := .ctx -}}
  {{- $page := .ctx.page -}}
  {{- $order := .order -}}
  {{- range $v := .data -}}
      {{- $restr := printf "<h([1-4]).*?id=\"%s\".*?>.*<\\/h[1-4]>" $v.ID -}}
      {{- $heading_html := index (findRE $restr $page.Content 1) 0 | default "" -}}
      {{- $content_starting_after_header := index (split $page.Content $heading_html) 1 -}}
      {{- $next_heading_html := index (findRE `<h([1-4]).*?>.*<\/h[1-4]>` $content_starting_after_header 1) 0 | default "" -}}
      {{- $content_block := index (split $content_starting_after_header $next_heading_html) 0 -}}
      {{- $section_header := $heading_html | plainify | htmlUnescape | safeHTML -}}

      {{ if and (ne $section_header "Further Reading") (ne $section_header "") }}
          {{- partial "algolia-section-chunks" (dict "ctx" $ctx "html" $content_block "header" $section_header "order" $order) -}}
          {{- $order = add $order 1 -}}
      {{- end -}}
      {{- $order = partial "heading-sections" (dict "data" $v.Headings "ctx" $ctx "order" $order) -}}
  {{- end -}}
  {{- return $order -}}
{{- end -}}

{{- /* Index the lead content (before the first H2/H3 heading), tab-split if applicable. */ -}}
{{- $ctx := (dict "context" $hugo_context "page" $page "title" $title "category" $category "subcategory" $subcategory "rank" $rank) -}}
{{- $first_heading := index (findRE `<h[23][^>]*>.*?</h[23]>` $page.Content 1) 0 | default "" -}}
{{- $lead_html := $page.Content -}}
{{- if $first_heading -}}
    {{- $lead_html = index (split $page.Content $first_heading) 0 -}}
{{- end -}}
{{- partial "algolia-section-chunks" (dict "ctx" $ctx "html" $lead_html "header" "" "order" -1) -}}

{{- /* Index each H2/H3 heading section. */ -}}
{{- $ord := partial "heading-sections" (dict "data" $page.Fragments.Headings "ctx" $ctx "order" 0) -}}
