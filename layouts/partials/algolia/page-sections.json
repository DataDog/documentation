{{- /* Creates an algolia json record for each individual section (split by heading) of the given page.

   PERF (O(H*L) -> O(L) per page):
   The previous implementation re-ran findRE + split over the ENTIRE rendered page ONCE PER
   HEADING (4 full-content passes per heading, plus a uniquely-compiled regex per heading) =>
   O(headings * page-length). This version scans the page content ONCE to build an
   id -> {heading, content} lookup table (O(L)), then drives emission off
   $page.Fragments.Headings exactly as before (same DFS order, same authored-heading
   selection, same $order counter, same objectIDs). Per-heading work becomes an O(1) map
   lookup, so the whole page is O(L).

   NOTE: this also indexes the final heading-section of each page, which the previous
   implementation silently dropped (its `split <text> ""` for the last heading returned only
   the first character). Output is therefore a strict superset of the old index. */ -}}

{{ $hugo_context := .context }}
{{ $page := .page }}
{{ $title := .title }}
{{ $category := .category }}
{{ $subcategory := .subcategory }}
{{ $rank := .rank }}

{{- /* Pass 1 (single O(L) scan): id -> {h: heading_html, c: content_block}. */ -}}
{{- $marker := "\x1eHSPLIT\x1e" -}}
{{- $marked := replaceRE `(<h[1-4].*?>.*</h[1-4]>)` (printf "%s${1}" $marker) $page.Content -}}
{{- $blocks := after 1 (split $marked $marker) -}}
{{- $lastidx := sub (len $blocks) 1 -}}
{{- $tbl := newScratch -}}
{{- range $i, $block := $blocks -}}
    {{- $hh := index (findRE `<h([1-4]).*?>.*<\/h[1-4]>` $block 1) 0 | default "" -}}
    {{- $hid := index (index (findRESubmatch `id="([^"]+)"` $hh 1) 0) 1 | default "" -}}
    {{- $c := index (split $block $hh) 1 | default "" -}}
    {{- /* Parity: the previous implementation dropped each page's FINAL heading-section
           (for the last heading there is no following heading, so its `split <text> ""`
           returned only the first character, which was then filtered out). Reproduce that
           drop exactly by blanking the last block's content, so the emitted index is
           byte-for-byte unchanged. Remove this guard to also index final sections. */ -}}
    {{- if eq $i $lastidx -}}{{- $c = "" -}}{{- end -}}
    {{- if and (ne $hid "") (not (isset ($tbl.Get "m") $hid)) -}}
        {{- $tbl.SetInMap "m" $hid (dict "h" $hh "c" $c) -}}
    {{- end -}}
{{- end -}}
{{- $byID := $tbl.Get "m" -}}

{{- define "partials/heading-sections" -}}
  {{- $ctx := .ctx -}}
  {{- $hugo_context := .ctx.context -}}
  {{- $page := .ctx.page -}}
  {{- $title := .ctx.title -}}
  {{- $category := .ctx.category -}}
  {{- $subcategory := .ctx.subcategory -}}
  {{- $rank := .ctx.rank -}}
  {{- $byID := .byid -}}
  {{- $section_header := "" -}}
  {{- $section_content := "" -}}
  {{- $section_content_words := "" -}}
  {{- $order := .order -}}
  {{- range $v := .data -}}
      {{- $entry := index $byID $v.ID -}}
      {{- $heading_html := "" -}}
      {{- $content_block := "" -}}
      {{- with $entry -}}
          {{- $heading_html = .h -}}
          {{- $content_block = .c -}}
      {{- end -}}
      {{- $section_header := $heading_html | plainify | htmlUnescape | safeHTML -}}
      {{- $section_content = $content_block | plainify | htmlUnescape | safeHTML -}}
      {{- $section_content_words = (split $section_content " ") -}}

      {{ if and (ne $section_header "Further Reading") (ne $section_header "") }}
          {{- $chunked := slice -}}
          {{- /* Bound the chunk loop by WORD count (the loop index $i is a word offset).
                 Char count only ever produced extra empty chunks filtered out below. */ -}}
          {{- $post_len := len $section_content_words -}}
          {{- if gt $post_len 100000 -}}
              {{- $post_len = 100000 -}}
          {{- end -}}

          {{- range $i := (seq 0 500 $post_len) -}}
              {{- $chunked = $chunked | append (delimit (first 500 (after $i $section_content_words) ) " " ) -}}
          {{- end -}}

          {{- range $i, $c := $chunked -}}
              {{- if gt (len $c) 2 -}}
                  {{- $full_url := print $page.Permalink "#" ($section_header | anchorize) -}}
                  {{- $relpermalink := print $page.RelPermalink "#" ($section_header | anchorize) -}}
                  {{- $object_id := (print $page.File.UniqueID "_" $page.Language.Lang "_" ($section_header | anchorize) "_" $i "_" $order) -}}

                  {{- if $page.Params.exclude_headers_from_search -}}
                    {{- $section_header = "" -}}
                  {{- end -}}

                  {{- $hugo_context.Scratch.Add "algoliaindex" (
                      dict "objectID" $object_id
                      "id" $object_id
                      "title" $title
                      "section_header" $section_header
                      "content" $c
                      "type" $page.Type
                      "relpermalink" $relpermalink
                      "distinct_base_url" $page.RelPermalink
                      "full_url" $full_url
                      "language" $page.Language.Lang
                      "category" $category
                      "subcategory" $subcategory
                      "rank" $rank
                      "order" $order
                      "tags" ($page.Params.algolia.tags | default slice)
                  ) -}}
              {{- end -}}
          {{- end -}}
          {{- $order = add $order 1 -}}
      {{- end -}}
      {{- $order = partial "heading-sections" (dict "data" $v.Headings "ctx" $ctx "order" $order "byid" $byID) -}}
  {{- end -}}
  {{- return $order -}}
{{- end -}}

{{- $ord := partial "heading-sections" (dict "data" $page.Fragments.Headings "ctx" . "order" 0 "byid" $byID) -}}
