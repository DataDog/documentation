{{- if ne hugo.Environment "development" -}}
{{- $urlmap := dict -}}
{{- range where .Site.AllPages "Kind" "!=" "home" -}}
    {{- $page := . -}}
    {{- if eq $page.Language.Lang "en" -}}
        {{- with $page.File -}}
            {{- $filepath := print "content/en/" .Path -}}
            {{- $urlmap = merge $urlmap (dict $page.RelPermalink $filepath) -}}
        {{- end -}}
    {{- end -}}
{{- end -}}
{{- $urlmap | jsonify -}}
{{- end -}}
