{
  "data": {
    "attributes": {
      "config": {
        "destinations": [
          {
            "id": "datadog-logs-destination",
            "inputs": [
              "my-processor-group"
            ],
            "type": "datadog_logs"
          }
        ],
        "processor_groups": [
          {
            "enabled": true,
            "id": "my-processor-group",
            "include": "service:my-service",
            "inputs": [
              "http-server-source"
            ],
            "processors": [
              {
                "enabled": true,
                "id": "filter-processor",
                "include": "status:error",
                "type": "filter"
              }
            ]
          }
        ],
        "sources": [
          {
            "id": "http-server-source",
            "type": "http_server",
            "auth_strategy": "none",
            "decoding": "json",
            "valid_tokens": [
              {
                "token_key": "HTTP_SERVER_TOKEN",
                "enabled": true,
                "path_to_token": {
                  "header": "X-Token"
                },
                "field_to_add": {
                  "key": "token_name",
                  "value": "primary_token"
                }
              },
              {
                "token_key": "HTTP_SERVER_TOKEN_BACKUP",
                "enabled": true,
                "path_to_token": "path"
              }
            ]
          }
        ]
      },
      "name": "Pipeline with HTTP server valid_tokens"
    },
    "type": "pipelines"
  }
}