{
  "data": {
    "attributes": {
      "config": {
        "destinations": [
          {
            "id": "datadog-logs-destination",
            "inputs": [
              "my-processor-group"
            ],
            "type": "datadog_logs"
          }
        ],
        "processor_groups": [
          {
            "enabled": true,
            "id": "my-processor-group",
            "include": "service:my-service",
            "inputs": [
              "datadog-agent-source"
            ],
            "processors": [
              {
                "enabled": true,
                "id": "parse-grok-processor",
                "include": "*",
                "type": "parse_grok",
                "field": "content",
                "rules": [
                  {
                    "include": "service:foo",
                    "match_rules": [
                      {
                        "name": "MyParsingRule",
                        "rule": "%{word:user}"
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ],
        "sources": [
          {
            "id": "datadog-agent-source",
            "type": "datadog_agent"
          }
        ]
      },
      "name": "Pipeline with Parse Grok Include Rules"
    },
    "type": "pipelines"
  }
}